---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import SidebarCard from '../components/SidebarCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	pageTitle?: string;
	pageIntro?: string;
	introLabel?: string;
	showPageIntro?: boolean;
	keywords?: string[];
	pageType?: "website" | "article";
	robots?: string;
	publishedTime?: string;
	modifiedTime?: string;
	section?: string;
	tags?: string[];
	schemas?: Record<string, unknown>[];
	breadcrumbs?: { name: string; path: string }[];
}

const {
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	image,
	pageTitle = SITE_TITLE,
	pageIntro = SITE_DESCRIPTION,
	introLabel = "Front Page",
	showPageIntro = true,
	keywords = [],
	pageType = "website",
	robots,
	publishedTime,
	modifiedTime,
	section,
	tags = [],
	schemas = [],
	breadcrumbs = [],
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={image}
			keywords={keywords}
			pageType={pageType}
			robots={robots}
			publishedTime={publishedTime}
			modifiedTime={modifiedTime}
			section={section}
			tags={tags}
			schemas={schemas}
			breadcrumbs={breadcrumbs}
		/>
	</head>
	<body>
		<div class="site-frame">
			<Header />

			<div class="site-grid">
				<aside class="left-rail">
					<div class="rail-stack">
						<SidebarCard title="Decision Stack" eyebrow="Pillars">
							<ul>
								<li>Brownfield planning and retrofit constraints</li>
								<li>Device selection for gateways, controllers, and field hardware</li>
								<li>Vendor comparison pages built for shortlist research</li>
							</ul>
						</SidebarCard>

						<SidebarCard title="Traffic Quality" eyebrow="Buyer Intent" compact={true}>
							<ul>
								<li>Engineers defining specifications and compatibility needs</li>
								<li>Integrators shaping shortlists for real deployment projects</li>
								<li>Readers close to distributor, OEM, or edge hardware decisions</li>
							</ul>
						</SidebarCard>

						<slot name="left-rail" />
					</div>
				</aside>

				<main class="content-column">
					<div class="content-stack">
						{
							showPageIntro && (
								<section class="page-intro">
									<p class="eyebrow">{introLabel}</p>
									<h1>{pageTitle}</h1>
									<p>{pageIntro}</p>
								</section>
							)
						}

						<slot />
					</div>
				</main>

				<aside class="right-rail">
					<div class="rail-stack">
						<AdSlot
							slotId="rail-vendor-showcase"
							format="rectangle"
							headline="Reserved manufacturer slot"
							note="Hold this rectangle for future gateway vendors, sensor makers, or distributor campaigns once the site earns steady spec-driven traffic."
						/>

						<SidebarCard title="Why This Traffic Matters" eyebrow="Commercial Fit">
							<p>
								Industrial device traffic gets more valuable as content becomes more specific. Buyers
								looking up enclosure fit, protocol support, or brownfield deployment detail tend to be
								far closer to real project spend than casual readers.
							</p>
						</SidebarCard>

						<AdSlot
							slotId="rail-distributor-tower"
							format="tower"
							headline="Spec-guide tower"
							note="Reserve this tall unit for future spec sheet promos, engineering downloads, or direct-sold vendor campaigns aligned with high-intent device pages."
						/>

						<slot name="right-rail" />
					</div>
				</aside>
			</div>

			<Footer />
		</div>
	</body>
</html>
