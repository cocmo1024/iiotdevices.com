---
import { getCollection } from 'astro:content';
import AdSlot from '../components/AdSlot.astro';
import PostPreviewCard from '../components/PostPreviewCard.astro';
import SidebarCard from '../components/SidebarCard.astro';
import ClassicShell from '../layouts/ClassicShell.astro';
import { SITE_DESCRIPTION, SITE_KEYWORDS } from '../consts';
import { SITE_PRIORITY_CLUSTERS, SITE_UPDATE_PLAYBOOK } from '../sitePlan';
import { sortPosts } from '../utils/content';

const posts = sortPosts(await getCollection('blog'));
const [featuredPost, ...morePosts] = posts;
---

<ClassicShell
	title="IIoT Devices | Device Selection, Deployment Planning, and Vendor Comparison"
	description={SITE_DESCRIPTION}
	pageTitle="Industrial device intelligence for real IIoT projects and high-intent buyers"
	pageIntro="IIoT Devices is designed as a premium English-language device desk for engineers, integrators, and technical buyers. The structure prioritizes brownfield deployment logic, device selection depth, and future sponsor placements sized for serious industrial demand generation."
	introLabel="IIoT Devices"
	keywords={[...SITE_KEYWORDS, 'industrial device desk', 'IIoT buyers guide', 'brownfield IIoT planning']}
>
	<Fragment slot="left-rail">
		<SidebarCard title="Start Here" eyebrow="Core Routes">
			<ul>
				<li><a href="/categories/deployment-planning/">Deployment Planning</a> for field constraints and retrofit strategy</li>
				<li><a href="/categories/device-selection/">Device Selection</a> for fit, compatibility, and hardware roles</li>
				<li><a href="/categories/vendor-comparison/">Vendor Comparison</a> for shortlist and buying research</li>
			</ul>
		</SidebarCard>

		<SidebarCard title="High-Value Traffic" eyebrow="Commercial Quality">
			<p>
				The strongest readers here are not casual consumers. They are people working through device
				choices, protocol fit, enclosure limits, and vendor shortlists for real projects.
			</p>
		</SidebarCard>
	</Fragment>

	<section class="hero-panel">
		<div class="hero-grid">
			<div>
				<p class="eyebrow">Spec Desk</p>
				<h2>Built for technical clarity before the buying decision</h2>
				<p>
					This brand should feel more like a useful engineering desk than a generic industrial blog:
					clear categories, practical deployment context, and content shaped around the questions that
					appear when a project is moving toward specification and spend.
				</p>
				<div class="chip-row">
					<a class="taxonomy-link" href="/categories/deployment-planning/">Deployment Planning</a>
					<a class="taxonomy-link" href="/categories/device-selection/">Device Selection</a>
					<a class="taxonomy-link" href="/categories/vendor-comparison/">Vendor Comparison</a>
					<a class="taxonomy-link" href="/blog/">Archive</a>
				</div>
			</div>

			<div class="hero-aside">
				<article class="detail-card">
					<p class="section-kicker">Reader Intent</p>
					<h3>Why the traffic is valuable</h3>
					<ul class="signal-list">
						<li>Readers are often defining specifications</li>
						<li>They care about compatibility, survivability, and deployment fit</li>
						<li>Many are close to distributor or OEM conversations</li>
					</ul>
				</article>

				<article class="detail-card">
					<p class="section-kicker">Long-Term Asset</p>
					<h3>What compounds here</h3>
					<p>
						Spec sheets, comparison frameworks, retrofit planning guides, and architecture explainers
						create durable search value and stronger B2B intent than broad industrial news.
					</p>
				</article>
			</div>
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Decision Desks</p>
				<h2>Three core editorial lanes for industrial buyers</h2>
			</div>
		</div>
		<div class="hub-grid">
			<article class="hub-card">
				<h4><a href="/categories/deployment-planning/">Deployment Planning</a></h4>
				<p>Brownfield logic, environment constraints, panel considerations, and project scoping detail.</p>
			</article>
			<article class="hub-card">
				<h4><a href="/categories/device-selection/">Device Selection</a></h4>
				<p>Category pages for gateways, controllers, sensors, conditioners, accessories, and fit-for-purpose hardware.</p>
			</article>
			<article class="hub-card">
				<h4><a href="/categories/vendor-comparison/">Vendor Comparison</a></h4>
				<p>Evaluation pages designed to support shortlists, commercial research, and later direct-sold campaigns.</p>
			</article>
		</div>
	</section>

	{featuredPost ? (
		<>
			<section class="section-block">
				<div class="section-head">
					<div>
						<p class="eyebrow">Lead Guide</p>
						<h2>Featured industrial device article</h2>
					</div>
				</div>
				<PostPreviewCard post={featuredPost} featured={true} />
			</section>

			<AdSlot
				slotId="home-device-banner"
				format="banner"
				headline="Reserved category sponsor leaderboard"
				note="This wide center-column unit is reserved for future OEM, distributor, or engineering-resource campaigns once the content library earns stronger category authority."
			/>
		</>
	) : (
		<section class="section-block">
			<div class="section-head">
				<div>
					<p class="eyebrow">Lead Guide</p>
					<h2>No posts published yet</h2>
				</div>
			</div>
			<p>Start with buyer guides, brownfield retrofit articles, and protocol explainers.</p>
		</section>
	)}

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Why This Can Win</p>
				<h2>Long-term SEO and B2B value are aligned here</h2>
			</div>
		</div>
		<div class="detail-grid">
			<article class="detail-card">
				<p class="section-kicker">Search Moat</p>
				<h3>Specific engineering questions</h3>
				<p>Pages built around compatibility, deployment environments, and device roles can hold value longer than generic product overviews.</p>
			</article>
			<article class="detail-card">
				<p class="section-kicker">Commercial Fit</p>
				<h3>Useful before the shortlist closes</h3>
				<p>High-intent content attracts readers who are defining requirements and can justify premium campaigns later.</p>
			</article>
			<article class="detail-card">
				<p class="section-kicker">Retention</p>
				<h3>Reference behavior matters</h3>
				<p>Spec-driven and retrofit content gets revisited during project planning, which helps the site become more than a one-time click.</p>
			</article>
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Editorial Engine</p>
				<h2>The long-term device strategy is now visible on-site</h2>
			</div>
		</div>
		<div class="detail-grid">
			<article class="detail-card">
				<p class="section-kicker">Topic Map</p>
				<h3><a href="/topics/">See the device cluster plan</a></h3>
				<p>
					The current top-priority cluster is <strong>{SITE_PRIORITY_CLUSTERS[0].title}</strong>, which
					is exactly the kind of brownfield topic that can earn high-intent industrial traffic over time.
				</p>
			</article>
			<article class="detail-card">
				<p class="section-kicker">Methodology</p>
				<h3><a href="/methodology/">Read how pages should be evaluated</a></h3>
				<p>
					The methodology page defines how the site should compare vendors, structure selectors, and
					avoid empty industrial content.
				</p>
			</article>
			<article class="detail-card">
				<p class="section-kicker">Cadence</p>
				<h3>{SITE_UPDATE_PLAYBOOK[0].title}</h3>
				<p>{SITE_UPDATE_PLAYBOOK[0].summary}</p>
			</article>
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Archive Stream</p>
				<h2>Recent IIoT device entries</h2>
			</div>
		</div>

		<div class="post-stream">
			{morePosts.length > 0 ? (
				morePosts.map((post) => <PostPreviewCard post={post} />)
			) : (
				<p>Use this stream for product category explainers and integration-focused posts that keep attracting engineering traffic.</p>
			)}
		</div>
	</section>

	<AdSlot
		slotId="home-mobile-webinar"
		format="mobile"
		headline="Reserved mobile industrial CTA"
		note="This smaller unit can later support a webinar, comparison download, or compact manufacturer message once mobile traffic quality is proven."
	/>
</ClassicShell>
