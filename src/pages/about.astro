---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`About | ${SITE.title}`}>
  <Header />
  <Main pageTitle="About" pageDesc={`About ${SITE.title}`}>
    <div class="app-prose max-w-app">
      <p>
        IIoT Devices is an independent English-language publication focused on industrial gateways, sensors, edge hardware, and brownfield connectivity decisions.
      </p>
      <p>
        The editorial direction emphasizes practical, durable coverage for readers comparing device classes, deployment tradeoffs, and integration options.
      </p>
    </div>
  </Main>
  <Footer />
</Layout>
