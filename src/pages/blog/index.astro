---
import { getCollection } from 'astro:content';
import AdSlot from '../../components/AdSlot.astro';
import PostPreviewCard from '../../components/PostPreviewCard.astro';
import SidebarCard from '../../components/SidebarCard.astro';
import ClassicShell from '../../layouts/ClassicShell.astro';
import { SITE_DESCRIPTION, SITE_KEYWORDS, SITE_TITLE } from '../../consts';
import { sortPosts } from '../../utils/content';

const posts = sortPosts(await getCollection('blog'));
---

<ClassicShell
	title={`${SITE_TITLE} | Blog`}
	description={SITE_DESCRIPTION}
	pageTitle="IIoT device archive"
	pageIntro="Keep long-term industrial search traffic in the center column with technical posts that compare device classes, explain protocols, and support real product evaluations."
	introLabel="Archive"
	keywords={[...SITE_KEYWORDS, 'IIoT archive', 'industrial device archive']}
	breadcrumbs={[
		{ name: 'Home', path: '/' },
		{ name: 'Devices', path: '/blog/' },
	]}
>
	<Fragment slot="left-rail">
		<SidebarCard title="Archive Goal" eyebrow="Evergreen">
			<p>
				These posts should answer recurring industrial buying questions: which device class fits, how
				to integrate it, and what criteria matter before deployment.
			</p>
		</SidebarCard>
	</Fragment>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">All Entries</p>
				<h3>Latest IIoT device coverage</h3>
			</div>
		</div>

		<div class="post-stream">
			{posts.length === 0 ? (
				<p>No posts yet. The archive is ready for spec sheets, vendor comparisons, and deployment notes.</p>
			) : (
				posts.map((post, index) => (
					<>
						<PostPreviewCard post={post} featured={index === 0} />
						{
							index === 0 && (
								<AdSlot
									slotId="archive-inline-vendor"
									format="inline"
									headline="Inline vendor comparison unit"
									note="A responsive unit after the lead article works well for gated spec tools, vendor launches, or distributor comparison campaigns."
								/>
							)
						}
					</>
				))
			)}
		</div>
	</section>
</ClassicShell>
